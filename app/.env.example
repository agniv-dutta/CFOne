# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1


# Application Settings
APP_ENV=development
DEBUG=true
SECRET_KEY=your_secret_key
JWT_EXPIRATION_HOURS=24


# Database
DATABASE_URL=sqlite:///./data/cfone.db


# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10


# Vector Store
VECTOR_STORE_PATH=./data/vector_store


# API Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# AWS Bedrock Models - Amazon Nova
NOVA_LITE_MODEL_ID=global.amazon.nova-2-lite-v1:0
NOVA_MODEL_ID=global.amazon.nova-2-lite-v1:0
NOVA_SONIC_MODEL_ID=global.amazon.nova-2-sonic-v1:0
EMBEDDING_MODEL_ID=global.amazon.nova-2-multimodal-embeddings-v1:0